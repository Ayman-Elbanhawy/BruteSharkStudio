<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
	
	<Product 
		Id="*" 
		Name="BruteShark Desktop Studio" 
		Language="1033" Version="1.2.17.0" 
		Manufacturer="Ayman Elbanhawy / Softwaremile.com" 
		UpgradeCode="9bec2dfd-0f30-466a-9077-cf86db101cac">
		
		<Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" InstallPrivileges="elevated"/>
		<WixVariable Id="WixUILicenseRtf" Value="LICENSE.rtf"/>
		<Property Id="PREVIOUSVERSIONSINSTALLED" Secure="yes" />
		<Upgrade Id="9bec2dfd-0f30-466a-9077-cf86db101cac">  
			<UpgradeVersion
				Minimum="1.0.0.0" Maximum="1.2.17.0"
				Property="PREVIOUSVERSIONSINSTALLED"
				IncludeMinimum="yes" IncludeMaximum="no" />
		</Upgrade>
		
		<InstallExecuteSequence>
			<RemoveExistingProducts Before="InstallInitialize" />
		</InstallExecuteSequence>
		
		<MediaTemplate EmbedCab="yes"/>
		<UIRef Id="WixUI_Minimal" />
		
		<Feature Id="ProductFeature" Title="BruteShark Desktop Studio" Level="1">
			<ComponentGroupRef Id="ProductComponents" />
			<ComponentGroupRef Id="HashcatComponents" />
			<ComponentRef Id="ApplicationShortcutDesktop"/>
			<ComponentRef Id="HashcatPathEnvironment"/>
		</Feature>
		
	</Product>

	<Fragment>
		<Directory Id="TARGETDIR" Name="SourceDir">
			
			<Directory Id="DesktopFolder" Name="Desktop">
				<Component Id="ApplicationShortcutDesktop" Guid="EE875EB0-FCFF-454F-8FF6-2F59B1085D5A">
					<Shortcut Id="ApplicationDesktopShortcut"
						Name="BruteShark Desktop Studio"
						Description="BruteShark Desktop Studio"
						Target="[INSTALLFOLDER]BruteSharkDesktopStudio.exe"
						WorkingDirectory="INSTALLFOLDER"/>
					<RemoveFolder Id="DesktopFolder" On="uninstall"/>
					<RegistryValue
						Root="HKCU"
						Key="Software/BruteSharkDesktopStudio"
						Name="installed"
						Type="integer"
						Value="1"
						KeyPath="yes"/>
				</Component>
			</Directory>
			
			<Directory Id="ProgramFilesFolder">
				<Directory Id="INSTALLFOLDER" Name="BruteShark Desktop Studio">
					<Directory Id="HASHCATFOLDER" Name="Hashcat" />
				</Directory>
			</Directory>
			
		</Directory>
	</Fragment>

	<Fragment>
		<ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">

			<Component Id="BruteSharkDesktopStudio.exe">
				<File Id="BruteSharkDesktopStudio.exe" Source="$(var.BruteSharkDesktop.TargetDir)" Name="BruteSharkDesktopStudio.exe" />
			</Component>
			
			<Component Id="Asn1.dll">
				<File Id="Asn1.dll" Source="$(var.BruteSharkDesktop.TargetDir)" Name="Asn1.dll" />
			</Component>

			<Component Id="AutomaticGraphLayout.dll">
				<File Id="AutomaticGraphLayout.dll" Source="$(var.BruteSharkDesktop.TargetDir)" Name="AutomaticGraphLayout.dll" />
			</Component>

			<Component Id="AutomaticGraphLayout.Drawing.dll">
				<File Id="AutomaticGraphLayout.Drawing.dll" Source="$(var.BruteSharkDesktop.TargetDir)" Name="AutomaticGraphLayout.Drawing.dll" />
			</Component>

			<Component Id="BruteForce.dll">
				<File Id="BruteForce.dll" Source="$(var.BruteSharkDesktop.TargetDir)" Name="BruteForce.dll" />
			</Component>

			<Component Id="BruteSharkDesktopStudio.deps.json">
				<File Id="BruteSharkDesktopStudio.deps.json" Source="$(var.BruteSharkDesktop.TargetDir)" Name="BruteSharkDesktopStudio.deps.json" />
			</Component>

			<Component Id="BruteSharkDesktopStudio.dll">
				<File Id="BruteSharkDesktopStudio.dll" Source="$(var.BruteSharkDesktop.TargetDir)" Name="BruteSharkDesktopStudio.dll" />
			</Component>

			<Component Id="BruteSharkDesktopStudio.dll.config">
				<File Id="BruteSharkDesktopStudio.dll.config" Source="$(var.BruteSharkDesktop.TargetDir)" Name="BruteSharkDesktopStudio.dll.config" />
			</Component>

			<Component Id="BruteSharkDesktopStudio.runtimeconfig.json">
				<File Id="BruteSharkDesktopStudio.runtimeconfig.json" Source="$(var.BruteSharkDesktop.TargetDir)" Name="BruteSharkDesktopStudio.runtimeconfig.json" />
			</Component>

			<Component Id="Microsoft.Msagl.GraphViewerGdi.dll">
				<File Id="Microsoft.Msagl.GraphViewerGdi.dll" Source="$(var.BruteSharkDesktop.TargetDir)" Name="Microsoft.Msagl.GraphViewerGdi.dll" />
			</Component>

			<Component Id="PacketDotNet.dll">
				<File Id="PacketDotNet.dll" Source="$(var.BruteSharkDesktop.TargetDir)" Name="PacketDotNet.dll" />
			</Component>

			<Component Id="PcapAnalyzer.dll">
				<File Id="PcapAnalyzer.dll" Source="$(var.BruteSharkDesktop.TargetDir)" Name="PcapAnalyzer.dll" />
			</Component>

			<Component Id="PcapProcessor.dll">
				<File Id="PcapProcessor.dll" Source="$(var.BruteSharkDesktop.TargetDir)" Name="PcapProcessor.dll" />
			</Component>

			<Component Id="SharpPcap.dll">
				<File Id="SharpPcap.dll" Source="$(var.BruteSharkDesktop.TargetDir)" Name="SharpPcap.dll" />
			</Component>

			<Component Id="DNS.dll">
				<File Id="DNS.dll" Source="$(var.BruteSharkDesktop.TargetDir)" Name="DNS.dll" />
			</Component>
      
			<Component Id="SIPSorcery.dll">
				<File Id="SIPSorcery.dll" Source="$(var.BruteSharkDesktop.TargetDir)" Name="SIPSorcery.dll" />
			</Component>

			<Component Id="SIPSorceryMedia.Abstractions.dll">
				<File Id="SIPSorceryMedia.Abstractions.dll" Source="$(var.BruteSharkDesktop.TargetDir)" Name="SIPSorceryMedia.Abstractions.dll" />
			</Component>

			<Component Id="BouncyCastle.Crypto.dll">
				<File Id="BouncyCastle.Crypto.dll" Source="$(var.BruteSharkDesktop.TargetDir)" Name="BouncyCastle.Crypto.dll" />
			</Component>

			<Component Id="DnsClient.dll">
				<File Id="DnsClient.dll" Source="$(var.BruteSharkDesktop.TargetDir)" Name="DnsClient.dll" />
			</Component>

			<Component Id="websocket.sharp.dll">
				<File Id="websocket.sharp.dll" Source="$(var.BruteSharkDesktop.TargetDir)" Name="websocket-sharp.dll" />
			</Component>

			<Component Id="Microsoft.Extensions.Logging.Abstractions.dll">
				<File Id="Microsoft.Extensions.Logging.Abstractions.dll" Source="$(var.BruteSharkDesktop.TargetDir)" Name="Microsoft.Extensions.Logging.Abstractions.dll" />
			</Component>
			
			<Component Id="CommonUi.dll">
				<File Id="CommonUi.dll" Source="$(var.BruteSharkDesktop.TargetDir)" Name="CommonUi.dll" />
			</Component>

			<Component Id="Newtonsoft.Json.dll">
				<File Id="Newtonsoft.Json.dll" Source="$(var.BruteSharkDesktop.TargetDir)" Name="Newtonsoft.Json.dll" />
			</Component>

			<Component Id="Octokit.dll">
				<File Id="Octokit.dll" Source="$(var.BruteSharkDesktop.TargetDir)" Name="Octokit.dll" />
			</Component>

		</ComponentGroup>
	</Fragment>

	<Fragment>
		<DirectoryRef Id="HASHCATFOLDER">
			<Component Id="HashcatPathEnvironment" Guid="0B1A81C9-B617-45B5-A88A-38E85490E7F0">
				<Environment Id="HashcatPath" Name="PATH" Value="[HASHCATFOLDER]" Permanent="no" Part="last" Action="set" System="yes" />
				<RegistryValue Root="HKLM" Key="Software\BruteSharkDesktopStudio" Name="HashcatPath" Type="integer" Value="1" KeyPath="yes" />
			</Component>
		</DirectoryRef>
	</Fragment>
</Wix>
